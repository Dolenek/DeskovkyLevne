{
  "name": "deskovky-levne",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite",
    "api:dev": "cd apps/api-go && go run ./cmd/server",
    "build": "tsc -b && node scripts/generate-sitemap.mjs && vite build && node scripts/prerender.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "prerender": "node scripts/prerender.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "security:sql": "node scripts/check-sql-function-privileges.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs && vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "lucide-react": "^1.11.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "playwright": "^1.58.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.14.0",
    "vite": "^7.1.7",
    "vitest": "^4.1.10"
  }
}
